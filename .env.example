# Netlify: Site settings > Environment variables
# Gere uma chave com pelo menos 32 caracteres.
SESSION_SECRET=troque_esta_chave_por_uma_chave_grande_com_mais_de_32_caracteres

# Discord OAuth admin
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Troque pelo domínio grátis do Netlify depois do deploy:
DISCORD_REDIRECT_URI=https://SEU-SITE.netlify.app/api/auth/discord/callback
DISCORD_ADMIN_USER_IDS=

# Mercado Pago Pix
MERCADOPAGO_ACCESS_TOKEN=
# Troque pelo domínio grátis do Netlify depois do deploy:
MERCADOPAGO_WEBHOOK_URL=https://SEU-SITE.netlify.app/api/webhooks/mercadopago

# Integração com o bot na Railway
DELIVERY_BOT_API_URL=https://SEU-BOT.up.railway.app/api/delivery
DELIVERY_BOT_API_SECRET=use_a_mesma_chave_do_BOT_API_SECRET_do_bot

# Em produção HTTPS no Netlify, deixe true
COOKIE_SECURE=true
